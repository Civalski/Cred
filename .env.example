# Copie para `.env.local` (não commite) e/ou defina as mesmas variáveis no painel do Vercel (Settings → Environment Variables).
#
# Desenvolvimento local: pode omitir este ficheiro — `npm run dev` usa PGlite (sem DATABASE_URL) e
# JWT de desenvolvimento. Para produção / `next start` / Neon, preencha abaixo.

# --- Local sem Neon (PGlite) — opcional: não precisa de ficheiro .env hoje em dia ---
# USE_PGLITE=1          # força embutido; fora isso, em `next dev` sem DATABASE_URL já é PGlite
# PGLITE_DATA_DIR=.pglite-data
# Dados vão para `.pglite-data/` (gitignored). Não defina DATABASE_URL se quiser só o embutido.

# URL com pooler (recomendada para a app no Next / serverless — ex.: Neon em produção)
DATABASE_URL=postgresql://USER:PASSWORD@HOST-POOLER/DB?sslmode=require

# URL direta (sem PgBouncer) — use em desenvolvimento para `drizzle-kit push` / migrations quando o pooler der problema
# Opcional: no Vercel você pode omitir; o `drizzle.config` cai de volta para `DATABASE_URL`.
# DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Sessão/JWT: obrigatório em produção (mín. 16 caracteres). Em `next dev` existe fallback inseguro.
# AUTH_SECRET=change-me-to-a-long-random-secret

# Senha do painel em /administrador (opcional; padrão em dev: 1234)
# ADMIN_PASSWORD=

# Cloudflare Turnstile (só em produção no Vercel: exige VERCEL_ENV=production + as duas variáveis)
# Chave secreta (siteverify) — no Vercel use o mesmo nome ou TURNSTILE_SECRET_KEY
# CLOUDFLARE_TURNSTILE_API_KEY=
# Site key do widget — alternativa: NEXT_PUBLIC_TURNSTILE_SITE_KEY
# TURNSTILE_SITE=
