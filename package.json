{
  "name": "cred-tech-test",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/sync-db.mjs && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:sync": "node scripts/sync-db.mjs",
    "db:migrate": "node scripts/sync-db.mjs",
    "db:migrate:files": "node scripts/apply-migration-files.mjs",
    "db:push": "drizzle-kit push",
    "db:push:pglite": "drizzle-kit push --config=drizzle.pglite.config.ts --force",
    "db:studio": "drizzle-kit studio",
    "db:test": "node scripts/test-db.cjs",
    "db:ensure-orders": "node scripts/ensure-orders-columns.cjs"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.2",
    "next": "16.2.4",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "typescript": "^5"
  }
}
